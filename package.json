    "react-dom": "^18.3.1",
    "react-redux": "^8.1.3",
    "react-router-dom": "^6.27.0",
    "redux": "^4.2.1",
    "redux-form": "^8.3.10",
    "redux-observable": "^2.0.0",
    "redux-saga": "^1.3.0",
    "redux-thunk": "^2.4.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@babel/preset-react": "^7.26.3",
